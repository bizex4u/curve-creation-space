# Supabase — get from https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# WhatsApp CTA — omit to hide the button entirely
VITE_WHATSAPP_NUMBER=919080500009

# Resend — set in Supabase Edge Function secrets, NOT here
# Run: supabase secrets set RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_API_KEY is a server-side secret — never put it in VITE_ env vars
